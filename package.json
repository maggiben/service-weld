{
  "name": "weld-cylinders",
  "version": "0.1.0",
  "private": true,
  "description": "Cylinder Custody, Circulation & Rental Management System (replaces the legacy Excel workbooks).",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=24.18 <25"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "pnpm run format:check && pnpm run typecheck",
    "lint:eslint": "eslint apps packages",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "node scripts/check-coverage.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "check:deps": "node scripts/check-deps.mjs",
    "check:id-length": "node scripts/check-id-length.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "db:up": "docker compose -f docker-compose.dev.yml up -d db",
    "db:load": "node scripts/db-load.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:invariants": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f db/tests/invariants.sql",
    "migrate:xls": "PYTHONPATH=migration python3 -m weld_migration",
    "migrate:xls:dry": "PYTHONPATH=migration python3 -m weld_migration --dry-run",
    "migrate:xls:backfill-capacity": "PYTHONPATH=migration python3 -m weld_migration --backfill-capacity",
    "migrate:xls:backfill-localities": "PYTHONPATH=migration python3 -m weld_migration --backfill-localities"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml,css,html}": "prettier --check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "pg": "^8.13.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.1",
      "js-yaml": ">=4.3.0",
      "postcss@<8.5.10": ">=8.5.10",
      "sharp@<0.35.0": ">=0.35.3",
      "test-exclude": "^7.0.2",
      "glob": "^13.0.6"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
