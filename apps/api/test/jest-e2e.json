{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@weld/schemas$": "<rootDir>/../../packages/schemas/src/index.ts",
    "^@weld/domain$": "<rootDir>/../../packages/domain/src/index.ts"
  }
}
