{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2021",
    "outDir": "./dist",
    "rootDir": "../..",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "isolatedModules": false,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@weld/schemas": ["../../packages/schemas/src/index.ts"],
      "@weld/domain": ["../../packages/domain/src/index.ts"]
    }
  },
  "include": ["src/**/*", "test/**/*"]
}
