{
  "name": "weld-cylinders",
  "version": "0.1.0",
  "private": true,
  "description": "Cylinder Custody, Circulation & Rental Management System (replaces the legacy Excel workbooks).",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=24.18 <25"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "pnpm run format:check && pnpm run typecheck",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "node scripts/check-coverage.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "db:up": "docker compose -f docker-compose.dev.yml up -d db",
    "db:load": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f schema.sql",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:invariants": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f db/tests/invariants.sql",
    "migrate:xls": "PYTHONPATH=migration python3 -m weld_migration",
    "migrate:xls:dry": "PYTHONPATH=migration python3 -m weld_migration --dry-run",
    "migrate:xls:backfill-capacity": "PYTHONPATH=migration python3 -m weld_migration --backfill-capacity"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml,css,html}": "prettier --check"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "pg": "^8.13.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
