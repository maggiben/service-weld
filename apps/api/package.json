{
  "name": "@weld/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "predev": "pnpm --filter @weld/schemas build && pnpm --filter @weld/domain build",
    "dev": "nest start --watch",
    "start": "node dist/apps/api/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "bootstrap:admin": "ts-node -r tsconfig-paths/register src/cli/bootstrap-admin.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.6",
    "@weld/domain": "workspace:*",
    "@weld/schemas": "workspace:*",
    "bwip-js": "^4.11.2",
    "kysely": "^0.28.17",
    "multer": "^2.2.0",
    "nestjs-zod": "^5.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.19.1",
    "pg": "^8.13.0",
    "pg-boss": "^10.1.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8",
    "@arcasdk/core": "2.0.0",
    "@peculiar/x509": "1.14.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bwip-js": "^3.2.3",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^3.2.4",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
