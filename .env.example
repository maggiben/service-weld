# Copy to .env for local dev. Never commit real secrets (see 012 ops).

# --- Database (003) ---
DATABASE_URL=postgres://postgres:test@localhost:5432/weld
DB_POOL_MAX=10

# --- API (004/005) ---
API_PORT=3000
API_GLOBAL_PREFIX=/api/v1
NODE_ENV=development

# --- Auth / JWT (005, D-8) ---
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_TTL=900          # seconds (~15 min)
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_TTL=2592000     # seconds (30 days)

# --- Bootstrap admin (D-11) ---
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login

# --- Business config (009/012, C1/C5) ---
BUSINESS_TIMEZONE=America/Argentina/Buenos_Aires
RENTAL_MIN_DAYS=0           # 0 = exact calendar days (D-14); override via Settings UI

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
# Marketing site (@weld/www → serviceweld.com). Login CTAs point at the app.
NEXT_PUBLIC_SITE_URL=http://localhost:3003
NEXT_PUBLIC_APP_URL=http://localhost:3001
# Legacy Vite key (removed with SPA → Next.js App Router, D-12)
# VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_DEFAULT_LOCALE=es

# --- Admin data migration (011 online via /admin/data) ---
# Directory for uploaded .xls, snapshots (pg_dump), and exports.
# On Railway, mount a volume here so Sync/Rollback survive redeploys.
# MIGRATION_DATA_DIR=./migration/data
# MIGRATION_PACKAGE_DIR=./migration
# PYTHON_BIN=python3
