{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@weld/schemas": ["../schemas/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "references": [{ "path": "../schemas" }]
}
